        {
          "name": "Verify OTP - POST /auth/verify-otp",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"otp\": \"123456\",\n  \"purpose\": \"VERIFY\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/verify-otp",
              "host": ["{{base_url}}"],
              "path": ["auth", "verify-otp"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "try {",
                  "  var res = pm.response.json();",
                  "  pm.test(\"Access token present\", function () { pm.expect(res.data.accessToken).to.exist; });",
                  "  if (res && res.data && res.data.accessToken) {",
                  "    pm.collectionVariables.set(\"access_token\", res.data.accessToken);",
                  "  }",
                  "  var sc = pm.response.headers.get(\"set-cookie\") || pm.response.headers.get(\"Set-Cookie\");",
                  "  if (sc) {",
                  "    var m = sc.match(/refreshToken=([^;]+);/);",
                  "    if (m) pm.collectionVariables.set(\"refresh_token\", m[1]);",
                  "  }",
                  "} catch (e) {}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": [
            {
              "name": "Success - 200 (returns accessToken & sets refresh cookie)",
              "originalRequest": {},
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [
                {
                  "key": "Set-Cookie",
                  "value": "refreshToken=<token>; HttpOnly"
                }
              ],
              "body": "{\"success\":true,\"message\":\"OTP verified successfully! You are now authenticated.\",\"meta\":null,\"data\":{\"accessToken\":\"<ACCESS_TOKEN>\"}}"
            },
            {
              "name": "Failure - 400 (Invalid/Expired OTP)",
