generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum OTPPurpose {
  VERIFY
  RESET
}

model User {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  fullName          String
  email             String    @unique
  password          String
  profilePic        String?   @default("")
  passwordChangedAt DateTime?
  isVerified        Boolean   @default(false)

  // OTP fields for email-based verification (hashed storage)
  otpCode         String?
  otpExpiry       DateTime?
  otpAttempts     Int         @default(0)
  otpRequestCount Int         @default(0)
  otpRequestReset DateTime?
  otpPurpose      OTPPurpose?

  // legacy/reset flags removed (link-based flows deprecated)

  role                UserRole         @default(USER)
  formSubmissionCount Int              @default(0)
  formSubmissions     FormSubmission[]
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@map("users")
}

enum FormType {
  GET_IN_TOUCH
  CONTACT
  CONSULTATION
}

model FormSubmission {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      FormType
  data      Json
  ip        String?
  createdAt DateTime @default(now())

  @@map("form_submissions")
}

model FormStats {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  formType         FormType @unique
  totalSubmissions Int      @default(0)
  uniqueUsers      Int      @default(0)

  @@map("form_stats")
}

enum Status {
  PROCESSING
  COMPLETED
  FAILED
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}
